#!/bin/sh
# pre-commit secret scan — PROTOCOL §5 (Dre 2026-07-16, handoff doc item 5).
# Pattern from 2026-07-16 PAT incident (Lesson-2026-07-16-live-pats-in-skill-files.md):
# real fleet tokens are github_pat_* / ghp_* / sk-ant-*. This hook scans staged
# content (added/copied) for those patterns + a few known raw secret shapes and
# BLOCKS the commit on any hit.
#
# Install (per repo, after dropping this file in a versioned location):
#   mkdir -p .git/hooks && ln -sf ../../<path-to-this-file> .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
# (or set core.hooksPath=<dir> and copy/symlink there)
#
# Override: SKIP_SECRET_SCAN=1 git commit ...   (rare; record why in the commit msg)
#
# Scope: matches PROTOCOL §5's existing .gitignore list (.env*, *.key, *.pem,
# auth.json, *token*, *secret*). Those files should never be staged at all;
# this hook is the backstop for material that slipped past the ignore.
#
# Filler exemption: lines that match the pattern BUT also contain obvious
# placeholder filler (..., xxx, XXXX, 0000, aaaa, etc.) are NOT flagged — those
# are test/example fixtures, not real secrets. Override with SKIP_SECRET_SCAN=1
# if a real token uses such filler (rare — real tokens have mixed-case entropy).

set -u

if [ "${SKIP_SECRET_SCAN:-0}" = "1" ]; then
  echo "pre-commit secret scan: SKIPPED (SKIP_SECRET_SCAN=1)" >&2
  exit 0
fi

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Patterns: <grep-ERE-regex>|<human description>. PEM literal-line uses grep -F.
PATTERNS='github_pat_[A-Za-z0-9_]{20,}|GitHub fine-grained PAT
ghp_[A-Za-z0-9]{20,}|GitHub classic PAT
gho_[A-Za-z0-9]{20,}|GitHub OAuth token
ghs_[A-Za-z0-9]{20,}|GitHub server token
ghr_[A-Za-z0-9]{20,}|GitHub refresh token
sk-ant-[A-Za-z0-9_-]{20,}|Anthropic API key
sk-[A-Za-z0-9]{20,}|OpenAI / generic sk- secret
xox[baprs]-[A-Za-z0-9-]{10,}|Slack token
AIzaSy[A-Za-z0-9_-]{20,}|Google API key
AKIA[0-9A-Z]{16}|AWS access key id
ASIA[0-9A-Z]{16}|AWS STS access key id
-----BEGIN [A-Z ]*PRIVATE KEY-----|PEM private key block'

# Filler marker pattern: real tokens don't contain runs of identical chars
# or ellipses. Matches '...', 'xxx...', 'XXXX', '0000', etc.
FILLER_PATTERN='(\.\.\.|xx+|XX+|xxxx+|XXXX+|0000+|1111+|aaaa+|AAAA+)'

FAIL=0
HITS=""
TMP_HITS=$(mktemp)
trap 'rm -f "$TMP_HITS"' EXIT

for f in $STAGED_FILES; do
  # Skip .gitignore-listed names (defense in depth)
  case "$f" in
    *.key|*.pem|*token*|*secret*|*.env|*.db|*.sqlite*|*.log) continue ;;
  esac

  if git ls-files --error-unmatch "$f" >/dev/null 2>&1; then
    CONTENT=$(git diff --cached -- "$f" | grep -E '^\+[^+]' || true)
  else
    CONTENT=$(git cat-file -p ":$f" 2>/dev/null || true)
  fi

  [ -z "$CONTENT" ] && continue
  printf '%s\n' "$CONTENT" > "$TMP_HITS"

  while IFS='|' read -r pat label; do
    [ -z "$pat" ] && continue
    case "$pat" in
      *'PRIVATE KEY'*|*'PRIVATE '*)
        if grep -qF -- "$pat" "$TMP_HITS" 2>/dev/null; then
          HIT_LINE=$(grep -nF -- "$pat" "$TMP_HITS" | head -1)
          FAIL=1
          HITS="$HITS
  $f  ->  $label
    line $HIT_LINE"
        fi
        ;;
      *)
        if grep -qE -- "$pat" "$TMP_HITS" 2>/dev/null; then
          HIT_LINE=$(grep -nE -- "$pat" "$TMP_HITS" | head -1)
          LINE_TEXT=$(printf '%s' "$HIT_LINE" | cut -d: -f2-)
          if ! printf '%s' "$LINE_TEXT" | grep -qE "$FILLER_PATTERN"; then
            FAIL=1
            HITS="$HITS
  $f  ->  $label
    line $HIT_LINE"
          fi
        fi
        ;;
    esac
  done <<EOF
$PATTERNS
EOF
done

if [ "$FAIL" = "1" ]; then
  echo "" >&2
  echo "❌ COMMIT BLOCKED — pre-commit secret scan found suspected credentials:" >&2
  printf -- '%s\n' "$HITS" >&2
  echo "" >&2
  echo "If this is a documented test fixture or you are redacting-in-progress," >&2
  echo "override with:  SKIP_SECRET_SCAN=1 git commit ..." >&2
  echo "(record the reason in the commit message body)" >&2
  exit 1
fi

exit 0
